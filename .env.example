# ============ WILDBERRIES ============
# seller.wildberries.ru → Настройки → Доступ к API → Создать токен
# Права: Статистика, Контент, Аналитика, Склад
WB_TOKEN=YOUR_WB_TOKEN_HERE

# ============ OZON ============
# seller.ozon.ru → Настройки → Seller API → Сгенерировать ключ
# Права: Analytics, Finance, Warehouses, Postings
OZON_CLIENT_ID=YOUR_CLIENT_ID
OZON_API_KEY=YOUR_API_KEY

# ============ POSTGRESQL ============
DATABASE_URL=postgresql://analytics_user:CHANGE_ME@localhost:5432/analytics_db

# ============ TELEGRAM (опционально) ============
# @BotFather → /newbot → скопировать токен
TG_BOT_TOKEN=YOUR_BOT_TOKEN
# @userinfobot → /start → скопировать chat_id
TG_CHAT_ID=YOUR_CHAT_ID
