[Unit]
Description=WB + Ozon Analytics API
After=network.target postgresql.service

[Service]
Type=simple
User=analytics
WorkingDirectory=/opt/analytics
EnvironmentFile=/opt/analytics/.env
ExecStart=/opt/analytics/venv/bin/uvicorn app:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
